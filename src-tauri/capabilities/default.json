{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "fs:default",
    "shell:allow-open",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/*",
          "all": true
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$APPDATA/*",
          "all": true
        },
        {
          "path": "$APPDATA/**",
          "all": true
        },
        {
          "path": "$DOCUMENT/*",
          "all": true
        },
        {
          "path": "$HOME/*",
          "all": true
        },
        {
          "path": "$DESKTOP/*",
          "all": true
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA/*",
          "all": true
        },
        {
          "path": "$APPDATA/**",
          "all": true
        }
      ]
    },
    "fs:allow-create",
    "fs:allow-read",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$APPDATA/*",
          "all": true
        },
        {
          "path": "$DOCUMENT/*",
          "all": true
        },
        {
          "path": "$HOME/*",
          "all": true
        }
      ]
    },
    "shell:default"
  ]
}
