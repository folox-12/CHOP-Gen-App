{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Generatsiy documentov CHOP",
  "version": "0.1.0",
  "identifier": "com.sergejvasilev.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Формирования документов ЧОП",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/iceberg.png",
      "icons/icon.ico"
    ]
  }
}
